# API de Kimi (Moonshot AI)
# Obtén tu API key en: https://platform.moonshot.cn/
KIMI_API_KEY=sk-tu-api-key-aqui
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Modelo de embeddings
EMBEDDING_MODEL=model-embedding-001
EMBEDDING_DIMENSION=1536

# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg2://semantic_user:semantic_pass@localhost:5432/semantic_search
