# ============================================
# PROVEEDOR DE EMBEDDINGS
# Opciones: "jina" | "local"
# ============================================
EMBEDDING_PROVIDER=jina

# ============================================
# CONFIGURACIÓN API (usada por Jina)
# Jina AI: https://jina.ai/embeddings
# NOTA: Jina AI requiere una API key gratuita.
#       Si no tienes una, usa EMBEDDING_PROVIDER=local
# ============================================
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.jina.ai/v1

# ============================================
# MODELO Y DIMENSIÓN (debe ser coherente con el proveedor)
# --------------------------------------------
# Jina (recomendado si tienes API key):
#   EMBEDDING_MODEL=jina-embeddings-v3
#   EMBEDDING_DIMENSION=1024
# --------------------------------------------
# Local (sentence-transformers, 100% offline):
#   EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
#   EMBEDDING_DIMENSION=384
# ============================================
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSION=1024

# ============================================
# BASE DE DATOS
# ============================================
DATABASE_URL=postgresql+psycopg2://semantic_user:semantic_pass@localhost:5432/semantic_search
